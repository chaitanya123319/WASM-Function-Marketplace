# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
POSTGRES_USER=wasmuser
POSTGRES_PASSWORD=wasmpass
POSTGRES_DB=wasmdb
DATABASE_URL=postgresql+asyncpg://wasmuser:wasmpass@postgres:5432/wasmdb

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ──────────────────────────────────────────────
# Pinata — https://app.pinata.cloud/developers/api-keys
# Create a key with: pinFileToIPFS, unpin, pinList permissions
# ──────────────────────────────────────────────
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_API_SECRET=YOUR_PINATA_API_SECRET
PINATA_JWT=YOUR_PINATA_JWT_TOKEN
PINATA_GATEWAY=https://gateway.pinata.cloud

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-value
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ──────────────────────────────────────────────
# Platform
# ──────────────────────────────────────────────
PLATFORM_FEE_PERCENT=20

# ──────────────────────────────────────────────
# Contributor Node
# ──────────────────────────────────────────────
NODE_PRIVATE_KEY=           # leave empty to auto-generate Ed25519 key on first run
BACKEND_URL=http://backend:8000
